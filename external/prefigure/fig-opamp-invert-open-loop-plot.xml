<diagram dimensions="(600,150)" margins="(40,5,5,10)" xmlns="https://prefigure.org">
  <definition>f(x)=2*sin(x)</definition>
  <definition>g(x)=-5*(sin(x))/fabs(sin(x))</definition>
  <coordinates bbox="(-1,-8,12,8)">
    <axes decorations="no" arrows="1">
      <xlabel alignment="sw"> Time (s) </xlabel>
      <ylabel alignment="w"> Voltage (V) </ylabel>
    </axes>          
    <tick-mark location="-5" axis="vertical">
      <m>-V_{S}</m>
    </tick-mark>
    <tick-mark location="-2" axis="vertical">
      <m>-V_\text{in,0}</m>
    </tick-mark>
    <tick-mark location="2" axis="vertical">
      <m>V_\text{in,0}</m>
    </tick-mark>
    <tick-mark location="5" axis="vertical">
      <m>V_{S}</m>
    </tick-mark>
    <graph at="Vin" function="f" domain="(0,10)" stroke="green" />
    <graph at="Vout" function="g" domain="(0,10)" N="1000" stroke="blue" dash="4 1"/>
    <legend anchor="(bbox[2], bbox[3])"
            alignment="sw" opacity="0.9"
            scale="0.9" vertical-skip="10">
      <item ref="Vin"><m>V_\text{in}</m></item>
      <item ref="Vout"><m>V_\text{out}</m></item>
      
    </legend>
  </coordinates>     
</diagram>